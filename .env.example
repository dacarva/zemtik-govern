# Copy to .env (gitignored) and fill in. Loaded by sandbox/e2e_openai_governed.py
# and sandbox/langfuse_boundary_smoke.py.

# Required: OpenAI key for the live gpt-5.4-nano agent run.
OPENAI_API_KEY=sk-...

# Optional: HMAC signing key for the durable audit trail. Defaults to a local
# demo secret if unset. The AuditReader must use the same value to verify.
ZEMTIK_AUDIT_SECRET=e2e-local-demo-secret

# Optional: Langfuse project keys, only needed for sandbox/langfuse_boundary_smoke.py
# (see docs/sandbox.md and docs/observability.md). Self-hosted-first: point
# LANGFUSE_HOST at your own instance, or https://cloud.langfuse.com for cloud.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000
